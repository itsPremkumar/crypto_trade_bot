# =================================================================
# Crypto Trade Bot - Environment Configuration Example
# =================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control!

# -----------------------------------------------------------------
# 1. Wallet Security
# -----------------------------------------------------------------
PRIVATE_KEY=your_private_key_here
KEYSTORE_PASSWORD=your_strong_password_here

# -----------------------------------------------------------------
# 2. IA / Decision Engine
# -----------------------------------------------------------------
# Provider: claude (Anthropic) or ollama (Local)
LLM_PROVIDER=claude

# -- Claude Settings --
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-3-5-sonnet-20240620
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500

# -- Ollama Settings (Local) --
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# -----------------------------------------------------------------
# 3. Blockchain RPC Nodes
# -----------------------------------------------------------------
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BASE_RPC_URL=https://mainnet.base.org

# 4. Telegram Control Center
# -----------------------------------------------------------------
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Optional: Hardcode your chat ID or leave empty to use pairing
TELEGRAM_CHAT_ID=
# Pairing Code: Use this to authorize your chat via `/pair <code_here>`
TELEGRAM_PAIRING_CODE=
# Mode: auto (executes trades), manual (asks for approval), paused
BOT_MODE=manual

# -----------------------------------------------------------------
# 5. Risk Management Parameters
# -----------------------------------------------------------------
MIN_BALANCE_USD=10.00
MIN_TRADE_USD=1.00
MAX_DAILY_LOSS_PERCENT=5
MAX_TRADE_PERCENT=20
SLIPPAGE_TOLERANCE=0.015
MAX_GAS_USD=0.50
CIRCUIT_BREAKER_LOSSES=3
CIRCUIT_BREAKER_PAUSE_MINUTES=60

# -----------------------------------------------------------------
# 6. Operational Settings
# -----------------------------------------------------------------
ACTIVE_CHAINS=polygon,bsc,base
DATABASE_URL=sqlite:///trades.db
LOG_LEVEL=INFO
