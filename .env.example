# =================================================================
# Crypto Trade Bot - Environment Configuration Example
# =================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control!

# -----------------------------------------------------------------
# 1. Wallet Security
# -----------------------------------------------------------------
# EVM Private Key (Polygon, BSC, Base)
PRIVATE_KEY=your_evm_private_key_here
# Solana Private Key (Base58 encoded)
SOLANA_PRIVATE_KEY=your_solana_private_key_here
SUI_PRIVATE_KEY=your_sui_private_key_here
KEYSTORE_PASSWORD=your_strong_password_here

# -----------------------------------------------------------------
# 2. IA / Decision Engine
# -----------------------------------------------------------------
# Provider: claude (Anthropic) or ollama (Local)
LLM_PROVIDER=claude

# -- Claude Settings --
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-3-5-sonnet-20240620
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500

# -- Ollama Settings (Local Fallback) --
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# -----------------------------------------------------------------
# 3. Blockchain RPC Nodes
# -----------------------------------------------------------------
POLYGON_RPC_URL=https://rpc-mainnet.matic.quiknode.pro
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BASE_RPC_URL=https://mainnet.base.org
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# -----------------------------------------------------------------
# 4. Telegram Control Center
# -----------------------------------------------------------------
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Optional: Hardcode your chat ID or leave empty to use pairing
TELEGRAM_CHAT_ID=
# Pairing Code: Use this to authorize your chat via /pair <code_here>
TELEGRAM_PAIRING_CODE=123
# Mode: auto (executes trades automatically) or manual (asks for approval)
BOT_MODE=auto
# Trading Mode: live (real money swaps) or paper (simulated)
TRADING_MODE=live
PAPER_START_BALANCE_USD=10.00

# -----------------------------------------------------------------
# 5. Risk Management Parameters ($10 Capital Focus)
# -----------------------------------------------------------------
MIN_BALANCE_USD=0.00
MIN_TRADE_USD=0.01
MAX_DAILY_LOSS_PERCENT=50
MAX_TRADE_PERCENT=100
SLIPPAGE_TOLERANCE=0.02
MAX_GAS_USD=5.00
CIRCUIT_BREAKER_LOSSES=3
CIRCUIT_BREAKER_PAUSE_MINUTES=60

# -----------------------------------------------------------------
# 6. Operational Settings
# -----------------------------------------------------------------
ACTIVE_CHAINS=solana,polygon,bsc,base
DATABASE_URL=sqlite:///trades.db
LOG_LEVEL=INFO
