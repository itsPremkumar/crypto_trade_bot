# Wallet Security
PRIVATE_KEY=your_private_key_here
KEYSTORE_PASSWORD=strong_password

# Anthropic LLM
ANTHROPIC_API_KEY=your_anthropic_key_here
LLM_MODEL=claude-sonnet-4-5
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500

# RPC URLs
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BASE_RPC_URL=https://mainnet.base.org

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
BOT_MODE=manual

# Risk Parameters
MIN_BALANCE_USD=7.00
MIN_TRADE_USD=1.00
MAX_DAILY_LOSS_PERCENT=5
MAX_TRADE_PERCENT=20
SLIPPAGE_TOLERANCE=0.015
MAX_GAS_USD=0.30
CIRCUIT_BREAKER_LOSSES=3
CIRCUIT_BREAKER_PAUSE_MINUTES=60

# Active chains
ACTIVE_CHAINS=polygon,bsc,base

# Database
DATABASE_URL=sqlite:///trades.db
